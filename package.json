{
  "name": "yepo-dog-icecream-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "kill:api": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-api.ps1",
    "server": "node server/index.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.2.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.24.1",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "streamifier": "^0.1.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4"
  },
  "engines": {
    "node": "20.x"
  }
}